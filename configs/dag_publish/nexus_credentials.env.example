# Generic example. For company usage, prefer one file per environment:
# - nexus_credentials.dev.env
# - nexus_credentials.uat.env
# - nexus_credentials.prod.env
#
# Required credentials.
NEXUS_USERNAME=your_username
NEXUS_PASSWORD=your_password
#
# Optional overrides. If omitted, the script uses built-in company defaults.
# NEXUS_REPOSITORY_URL=https://nexus302.systems.uk.hsbc:8081/nexus/repository/raw-alm-uat_n3p
# NEXUS_PATH_PREFIX=com/hsbc/gdt/et/fctm/1646753/CHG123456
# NEXUS_BASE_URL=https://nexus302.systems.uk.hsbc:8081/nexus
# NEXUS_REPOSITORY=raw-alm-uat_n3p
NEXUS_TIMEOUT_SECONDS=60
NEXUS_INSECURE=false
